{
  "type": "module",
  "scripts": {
    "dev": "npm run dev:client",
    "dev:client": "vite --host localhost",
    "dev:server": "npm --prefix ../server run dev",
    "dev:full": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host localhost"
  },
  "dependencies": {
    "@stellar/freighter-api": "^6.0.1",
    "@stellar/stellar-sdk": "^16.0.1",
    "@vitejs/plugin-react": "latest",
    "concurrently": "^10.0.3",
    "framer-motion": "latest",
    "html2canvas": "^1.4.1",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "latest"
  }
}
