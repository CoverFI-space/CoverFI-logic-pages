{
  "type": "module",
  "scripts": {
    "dev": "npm run dev:client",
    "dev:client": "vite --host localhost",
    "dev:server": "npm --prefix ../server run dev",
    "dev:full": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host localhost"
  },
